---
interface Props {
  title: string;
  description: string;
  collection: string;
  slug: string;
}

const { title, description, collection, slug } = Astro.props;
const articleUrl = `https://brody.gg/${slug}`;
const xShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(articleUrl)}`;
---

<div class="share-container"
  data-title={title}
  data-description={description}
  data-collection={collection}
  data-url={articleUrl}>

  <button class="share-btn" data-share-open aria-label="Share this article">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
      <polyline points="16 6 12 2 8 6"/>
      <line x1="12" y1="2" x2="12" y2="15"/>
    </svg>
  </button>

  <div class="share-overlay" data-share-overlay>
    <div class="share-modal" data-share-modal>
      <div class="share-modal-header">
        <span class="share-modal-title">Share</span>
        <button class="share-close" data-share-close aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div class="share-preview" data-share-preview>
        <canvas data-share-canvas></canvas>
      </div>

      <div class="share-format-toggle">
        <button class="format-btn active" data-format="story">Story</button>
        <button class="format-btn" data-format="post">Post</button>
      </div>

      <div class="share-actions">
        <button class="share-action-btn" data-download>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span>Save</span>
        </button>
        <a class="share-action-btn" href={xShareUrl} target="_blank" rel="noopener" data-share-x>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span>Post</span>
        </a>
        <button class="share-action-btn" data-copy-link>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span>Copy Link</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .share-container {
    display: inline-flex;
  }

  .share-btn {
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 5px 8px;
    cursor: pointer;
    color: var(--text);
    opacity: 0.4;
    transition: opacity 0.2s ease;
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .share-btn:hover {
    opacity: 0.8;
  }

  /* --- Overlay --- */
  .share-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .share-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* --- Modal --- */
  .share-modal {
    background: #161616;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 1.25rem;
    max-width: 400px;
    width: 92%;
    max-height: 92vh;
    overflow-y: auto;
    transform: scale(0.96) translateY(8px);
    transition: transform 0.25s ease;
  }

  .share-overlay.active .share-modal {
    transform: scale(1) translateY(0);
  }

  .share-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .share-modal-title {
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .share-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    transition: color 0.15s;
  }

  .share-close:hover {
    color: #fff;
  }

  /* --- Preview --- */
  .share-preview {
    display: flex;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 12px;
    padding: 0.75rem;
  }

  .share-preview canvas {
    max-height: 440px;
    width: auto;
    max-width: 100%;
    border-radius: 8px;
    display: block;
  }

  /* --- Format Toggle --- */
  .share-format-toggle {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin: 0.85rem 0;
  }

  .format-btn {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 0.35rem 1rem;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .format-btn:hover {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
  }

  .format-btn.active {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  /* --- Actions --- */
  .share-actions {
    display: flex;
    gap: 0.4rem;
  }

  .share-action-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 0.7rem 0.4rem;
    color: rgba(255, 255, 255, 0.65);
    cursor: pointer;
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 500;
    font-family: inherit;
    transition: all 0.15s ease;
  }

  .share-action-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .share-action-btn.success {
    background: rgba(40, 200, 80, 0.15);
    border-color: rgba(40, 200, 80, 0.3);
    color: #4ade80;
  }

  @media (max-width: 480px) {
    .share-modal {
      width: 96%;
      padding: 1rem;
      border-radius: 16px;
    }
    .share-preview canvas {
      max-height: 380px;
    }
  }
</style>

<script>
  function initShareCard() {
    const container = document.querySelector('.share-container') as HTMLElement;
    if (!container || container.dataset.init === '1') return;
    container.dataset.init = '1';

    const title = container.dataset.title || '';
    const description = container.dataset.description || '';
    const collection = container.dataset.collection || 'thoughts';
    const articleUrl = container.dataset.url || '';

    const overlay = container.querySelector('[data-share-overlay]') as HTMLElement;
    const modal = container.querySelector('[data-share-modal]') as HTMLElement;
    const canvas = container.querySelector('[data-share-canvas]') as HTMLCanvasElement;
    const openBtn = container.querySelector('[data-share-open]') as HTMLElement;
    const closeBtn = container.querySelector('[data-share-close]') as HTMLElement;
    const formatBtns = container.querySelectorAll('.format-btn');
    const downloadBtn = container.querySelector('[data-download]') as HTMLElement;
    const copyBtn = container.querySelector('[data-copy-link]') as HTMLElement;

    let currentFormat: 'story' | 'post' = 'story';

    // --- Open / Close ---
    function open() {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      renderCard(currentFormat);
    }

    function close() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

    // --- Format Toggle ---
    formatBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        formatBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFormat = (btn as HTMLElement).dataset.format as 'story' | 'post';
        renderCard(currentFormat);
      });
    });

    // --- Download ---
    downloadBtn.addEventListener('click', () => {
      canvas.toBlob(async (blob) => {
        if (!blob) return;
        const file = new File([blob], `brody-gg-${currentFormat}.png`, { type: 'image/png' });

        // Mobile: use native share sheet (saves to photos)
        if (navigator.share && navigator.canShare?.({ files: [file] })) {
          try {
            await navigator.share({ files: [file] });
            flashSuccess(downloadBtn);
          } catch (e: any) {
            if (e.name !== 'AbortError') fallbackDownload(blob);
          }
          return;
        }

        // Desktop: standard download
        fallbackDownload(blob);
      }, 'image/png');
    });

    function fallbackDownload(blob: Blob) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `brody-gg-${currentFormat}.png`;
      a.click();
      URL.revokeObjectURL(url);
      flashSuccess(downloadBtn);
    }

    // --- Copy Link ---
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(articleUrl).then(() => {
        const label = copyBtn.querySelector('span');
        if (label) {
          const orig = label.textContent;
          label.textContent = 'Copied!';
          flashSuccess(copyBtn);
          setTimeout(() => { label.textContent = orig; }, 1800);
        }
      });
    });

    function flashSuccess(btn: HTMLElement) {
      btn.classList.add('success');
      setTimeout(() => btn.classList.remove('success'), 1500);
    }

    // =============================================
    //  Canvas Rendering
    // =============================================

    const configs = {
      story: { w: 1080, h: 1920, pad: 90, titleSize: 72, descSize: 32, labelSize: 20, titleStartY: 1080, labelY: 1020, titleLeading: 92, descLeading: 46, maxTitleLines: 5, maxDescLines: 3, dividerY: 1740, brandY: 1810 },
      post:  { w: 1080, h: 1350, pad: 90, titleSize: 62, descSize: 28, labelSize: 17, titleStartY: 740, labelY: 688, titleLeading: 78, descLeading: 42, maxTitleLines: 4, maxDescLines: 2, dividerY: 1170, brandY: 1240 },
    };

    const colorSchemes: Record<string, { c1: number[]; c2: number[]; c3: number[] }> = {
      thoughts:    { c1: [255, 20, 20],  c2: [160, 20, 60],  c3: [255, 80, 50] },
      projects:    { c1: [220, 20, 90],  c2: [100, 30, 180], c3: [255, 50, 120] },
      experiments: { c1: [255, 70, 0],   c2: [190, 80, 10],  c3: [255, 40, 40] },
    };

    function font(weight: number, size: number) {
      return `${weight} ${size}px -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif`;
    }

    function wrapText(ctx: CanvasRenderingContext2D, text: string, maxWidth: number, maxLines: number): string[] {
      const words = text.split(' ');
      const lines: string[] = [];
      let cur = '';

      for (const word of words) {
        const test = cur ? `${cur} ${word}` : word;
        if (ctx.measureText(test).width > maxWidth && cur) {
          lines.push(cur);
          if (lines.length >= maxLines) {
            const last = lines[lines.length - 1];
            // Truncate last line with ellipsis if needed
            let truncated = last;
            while (ctx.measureText(truncated + '...').width > maxWidth && truncated.length > 0) {
              truncated = truncated.slice(0, -1);
            }
            lines[lines.length - 1] = truncated + '...';
            return lines;
          }
          cur = word;
        } else {
          cur = test;
        }
      }

      if (cur) {
        if (lines.length >= maxLines) {
          const last = lines[lines.length - 1];
          let truncated = last;
          while (ctx.measureText(truncated + '...').width > maxWidth && truncated.length > 0) {
            truncated = truncated.slice(0, -1);
          }
          lines[lines.length - 1] = truncated + '...';
        } else {
          lines.push(cur);
        }
      }

      return lines;
    }

    function drawTriangle(ctx: CanvasRenderingContext2D, cx: number, cy: number, size: number) {
      const h = size * 0.866;
      ctx.beginPath();
      ctx.moveTo(cx, cy - h * 0.667);
      ctx.lineTo(cx + size * 0.5, cy + h * 0.333);
      ctx.lineTo(cx - size * 0.5, cy + h * 0.333);
      ctx.closePath();
    }

    function renderCard(format: 'story' | 'post') {
      const c = configs[format];
      const scheme = colorSchemes[collection] || colorSchemes.thoughts;
      const { c1, c2, c3 } = scheme;

      canvas.width = c.w;
      canvas.height = c.h;
      const ctx = canvas.getContext('2d')!;

      // --- 1. Solid Background ---
      ctx.fillStyle = '#0a0a0a';
      ctx.fillRect(0, 0, c.w, c.h);

      // --- 2. Gradient Orbs ---
      // Primary (upper-right area)
      let g = ctx.createRadialGradient(c.w * 0.78, c.h * 0.18, 0, c.w * 0.78, c.h * 0.18, c.w * 0.65);
      g.addColorStop(0, `rgba(${c1[0]},${c1[1]},${c1[2]}, 0.45)`);
      g.addColorStop(0.5, `rgba(${c1[0]},${c1[1]},${c1[2]}, 0.12)`);
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, c.w, c.h);

      // Secondary (lower-left area)
      g = ctx.createRadialGradient(c.w * 0.12, c.h * 0.62, 0, c.w * 0.12, c.h * 0.62, c.w * 0.55);
      g.addColorStop(0, `rgba(${c2[0]},${c2[1]},${c2[2]}, 0.35)`);
      g.addColorStop(0.5, `rgba(${c2[0]},${c2[1]},${c2[2]}, 0.08)`);
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, c.w, c.h);

      // Tertiary center glow
      g = ctx.createRadialGradient(c.w * 0.45, c.h * 0.38, 0, c.w * 0.45, c.h * 0.38, c.w * 0.4);
      g.addColorStop(0, `rgba(${c3[0]},${c3[1]},${c3[2]}, 0.1)`);
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, c.w, c.h);

      // --- 3. Decorative Triangles ---
      ctx.save();

      // Large triangle with glow
      const triSize = c.w * 0.58;
      const triCx = c.w * 0.48;
      const triCy = c.h * 0.28;
      ctx.shadowColor = `rgba(${c1[0]},${c1[1]},${c1[2]}, 0.2)`;
      ctx.shadowBlur = 80;
      drawTriangle(ctx, triCx, triCy, triSize);
      const tg = ctx.createLinearGradient(triCx, triCy - triSize * 0.5, triCx, triCy + triSize * 0.35);
      tg.addColorStop(0, `rgba(${c1[0]},${c1[1]},${c1[2]}, 0.1)`);
      tg.addColorStop(1, `rgba(${c1[0]},${c1[1]},${c1[2]}, 0.02)`);
      ctx.fillStyle = tg;
      ctx.fill();
      ctx.shadowColor = 'transparent';
      ctx.shadowBlur = 0;

      // Second smaller triangle
      const tri2Size = c.w * 0.28;
      const tri2Cx = c.w * 0.72;
      const tri2Cy = c.h * 0.19;
      drawTriangle(ctx, tri2Cx, tri2Cy, tri2Size);
      ctx.fillStyle = `rgba(${c2[0]},${c2[1]},${c2[2]}, 0.06)`;
      ctx.fill();

      // Third tiny triangle
      const tri3Size = c.w * 0.14;
      const tri3Cx = c.w * 0.25;
      const tri3Cy = c.h * 0.42;
      drawTriangle(ctx, tri3Cx, tri3Cy, tri3Size);
      ctx.fillStyle = `rgba(${c3[0]},${c3[1]},${c3[2]}, 0.05)`;
      ctx.fill();

      ctx.restore();

      // --- 4. Vignette ---
      g = ctx.createRadialGradient(c.w / 2, c.h * 0.45, c.h * 0.2, c.w / 2, c.h * 0.45, c.h * 0.75);
      g.addColorStop(0, 'rgba(0,0,0,0)');
      g.addColorStop(1, 'rgba(0,0,0,0.4)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, c.w, c.h);

      // --- 5. Grain ---
      const imageData = ctx.getImageData(0, 0, c.w, c.h);
      const d = imageData.data;
      for (let i = 0; i < d.length; i += 8) {
        const n = (Math.random() - 0.5) * 22;
        d[i] += n; d[i + 1] += n; d[i + 2] += n;
      }
      ctx.putImageData(imageData, 0, 0);

      // --- 6. Title ---
      ctx.fillStyle = '#ffffff';
      ctx.font = font(700, c.titleSize);
      const maxTextW = c.w - c.pad * 2;
      const titleLines = wrapText(ctx, title, maxTextW, c.maxTitleLines);
      let y = c.titleStartY;
      for (const line of titleLines) {
        ctx.fillText(line, c.pad, y);
        y += c.titleLeading;
      }

      // --- 8. Description ---
      if (description) {
        y += 4;
        ctx.fillStyle = 'rgba(255,255,255, 0.45)';
        ctx.font = font(400, c.descSize);
        const descLines = wrapText(ctx, description, maxTextW, c.maxDescLines);
        for (const line of descLines) {
          ctx.fillText(line, c.pad, y);
          y += c.descLeading;
        }
      }

      // --- 9. Divider ---
      ctx.strokeStyle = 'rgba(255,255,255, 0.12)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(c.pad, c.dividerY);
      ctx.lineTo(c.pad + 180, c.dividerY);
      ctx.stroke();

      // --- 10. Branding ---
      // Small red triangle
      const bTriSize = 20;
      const bTriX = c.pad + bTriSize * 0.5;
      const bTriY = c.brandY;
      drawTriangle(ctx, bTriX, bTriY, bTriSize);
      ctx.fillStyle = '#FF0000';
      ctx.fill();

      // "brody.gg"
      ctx.fillStyle = 'rgba(255,255,255, 0.55)';
      ctx.font = font(500, 26);
      ctx.fillText('brody.gg', bTriX + bTriSize * 0.5 + 14, bTriY + 9);
    }
  }

  initShareCard();
  document.addEventListener('astro:page-load', () => {
    // Reset init flag for view transitions
    const c = document.querySelector('.share-container') as HTMLElement;
    if (c) c.dataset.init = '';
    initShareCard();
  });
</script>
