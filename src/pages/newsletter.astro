---
import Layout from '../layouts/Layout.astro';
import ShareCard from '../components/ShareCard.astro';

export const prerender = true;
---

<Layout title="Subscribe - Broderick Cotter" description="Subscribe to Broderick Cotter's newsletter. Get new experiments, projects, and updates delivered to your inbox once or twice a month.">
    <main class="newsletter-page">
        <a href="/" class="close-btn" aria-label="Back to site">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </a>

        <div class="newsletter-content">
            <div class="newsletter-header">
                <div class="triangle-icon">
                    <img src="/assets/svg/triangle.svg" alt="" width="40" height="40">
                </div>
                <h1>Broderick's Newsletter</h1>
                <p class="tagline">Projects, experiments, and thoughts from a curious engineer. Once or twice a month, straight to your inbox.</p>
            </div>

            <form id="newsletter-form" class="subscribe-form">
                <input
                    type="email"
                    id="email-input"
                    placeholder="your@email.com"
                    required
                    autocomplete="email"
                />
                <button type="submit">Subscribe</button>
            </form>

            <p class="no-spam">No spam. Unsubscribe anytime.</p>

            <div class="divider"></div>

            <a href="/thoughts" class="read-link">Read past writings</a>

            <div class="share-wrapper">
                <ShareCard title="Broderick's Newsletter" description="Projects, experiments, and thoughts from a curious engineer." collection="thoughts" slug="newsletter" />
            </div>
        </div>
    </main>
</Layout>

<style>
    .newsletter-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
    }

    .close-btn {
        position: fixed;
        top: 2rem;
        right: 2rem;
        color: var(--text);
        opacity: 0.4;
        transition: opacity 0.2s ease;
        z-index: 10;
        text-decoration: none;
        line-height: 0;
    }

    .close-btn:hover {
        opacity: 1;
    }

    .newsletter-content {
        max-width: 400px;
        width: 100%;
        text-align: center;
    }

    .newsletter-header {
        margin-bottom: 2rem;
    }

    .triangle-icon {
        margin-bottom: 1.5rem;
    }

    .triangle-icon img {
        opacity: 0.8;
    }

    h1 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        line-height: 1.3;
    }

    .tagline {
        font-size: 1rem;
        opacity: 0.6;
        line-height: 1.6;
    }

    .subscribe-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .subscribe-form input[type="email"] {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 16px;
        background-color: var(--bg);
        color: var(--text);
        transition: border-color 0.2s;
        text-align: center;
    }

    .subscribe-form input[type="email"]:focus {
        outline: none;
        border-color: var(--text);
    }

    .subscribe-form input[type="email"]::placeholder {
        opacity: 0.4;
    }

    .subscribe-form button {
        padding: 0.875rem 1rem;
        background-color: var(--accent);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .subscribe-form button:hover {
        opacity: 0.85;
    }

    .subscribe-form button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .no-spam {
        font-size: 0.8rem;
        opacity: 0.35;
        margin-top: 0.75rem;
    }

    .divider {
        width: 40px;
        height: 1px;
        background-color: var(--border-color);
        margin: 2rem auto;
    }

    .read-link {
        color: var(--text);
        opacity: 0.5;
        font-size: 0.9rem;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .read-link:hover {
        opacity: 1;
    }

    .share-wrapper {
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
    }

    @media (max-width: 768px) {
        .close-btn {
            top: 1.5rem;
            right: 1.5rem;
        }
    }
</style>

<script is:inline>
    function initNewsletterPage() {
        const form = document.getElementById('newsletter-form');
        const emailInput = document.getElementById('email-input');
        const submitBtn = form?.querySelector('button[type="submit"]');

        if (!form || !emailInput || !submitBtn) return;
        if (form.dataset.initialized) return;
        form.dataset.initialized = 'true';

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = emailInput.value.trim();
            if (!email) return;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Subscribing...';

            try {
                const response = await fetch('/api/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email }),
                    keepalive: true,
                });

                const data = await response.json();

                if (response.ok) {
                    submitBtn.textContent = data.message || 'Subscribed!';
                    submitBtn.style.backgroundColor = 'rgba(255, 0, 0, 0.6)';
                    emailInput.value = '';
                    setTimeout(() => {
                        submitBtn.textContent = 'Subscribe';
                        submitBtn.style.backgroundColor = '';
                        submitBtn.disabled = false;
                    }, 3000);
                } else {
                    submitBtn.textContent = data.error || 'Error!';
                    submitBtn.style.backgroundColor = 'red';
                    setTimeout(() => {
                        submitBtn.textContent = 'Subscribe';
                        submitBtn.style.backgroundColor = '';
                        submitBtn.disabled = false;
                    }, 3000);
                }
            } catch (error) {
                submitBtn.textContent = 'Network error!';
                submitBtn.style.backgroundColor = 'red';
                setTimeout(() => {
                    submitBtn.textContent = 'Subscribe';
                    submitBtn.style.backgroundColor = '';
                    submitBtn.disabled = false;
                }, 3000);
            }
        });
    }

    initNewsletterPage();
    document.addEventListener('astro:page-load', initNewsletterPage);
</script>
